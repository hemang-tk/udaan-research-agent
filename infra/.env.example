# Copy to infra/.env and adjust. Never commit the real .env.
# 12-factor: every endpoint/credential/model is config. No hardcoded host in code.
#
# This is the HOSTED-ONLY build (Hugging Face + external APIs). All heavy compute
# is on hosted services (Groq/Gemini/Anthropic, Cohere, LlamaParse, Qdrant Cloud,
# Supabase S3, Neon Postgres). There is no local model / Ollama / Redis / MinIO.

# --- Vector store (Qdrant Cloud) ---
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=

# --- Object storage (Supabase S3-compatible) ---
S3_ENDPOINT=https://YOUR-PROJECT.supabase.co/storage/v1/s3
S3_BUCKET=research-vault
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# --- Persistence (Neon Postgres) — research-session History ---
# Unset DATABASE_URL to disable persistence (runs stay ephemeral).
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Orchestrator API ---
# Orchestrator's own port (separate from the Python services' generic PORT).
ORCHESTRATOR_PORT=8080
# Comma-separated origins allowed to call the API from a browser (CORS).
# Set this to your deployed frontend, e.g. https://your-site.netlify.app
# Leave empty for local dev (any origin is reflected). See DEPLOY.md.
CORS_ORIGINS=
# Phase 2 academic-graph fan-out: per-provider timeout (ms). The 4s default suits
# a datacenter; raise to ~25000 behind a slower connection.
GATEWAY_TIMEOUT_MS=

# --- LLM / embeddings / rerank providers (all hosted) ---
# LLM_PROVIDER may be a COMMA-SEPARATED list (e.g. "gemini,groq") to round-robin
# across providers and fail over on rate-limit — independent free tiers share the
# load, so a run only stalls if every provider is limited at once. Give each its
# own model via LLM_MODEL_<PROVIDER> below (LLM_MODEL is the fallback).
LLM_PROVIDER=anthropic                 # gemini | groq | anthropic (or a comma list)
EMBEDDING_PROVIDER=cohere              # cohere
RERANK_PROVIDER=cohere                 # cohere

LLM_MODEL=claude-haiku-4-5             # a valid model id for your LLM_PROVIDER
# Per-provider model overrides — needed when LLM_PROVIDER lists several providers.
# LLM_MODEL_GEMINI=gemini-2.5-flash
# LLM_MODEL_GROQ=llama-3.3-70b-versatile
# LLM_MODEL_ANTHROPIC=claude-haiku-4-5
EMBEDDING_MODEL=embed-english-v3.0
RERANK_MODEL=rerank-v3.5

# Chat (RAG over a research's papers): a strict-priority chain — free provider
# first, paid backstop. Falls back to LLM_PROVIDER when unset.
CHAT_LLM_PROVIDER=groq,anthropic
CHAT_CANDIDATE_K=20                     # wide vector candidate set before rerank
ENABLE_CRAG=true                        # corrective retrieval grading (false to skip)

# API keys (only the ones your selected providers need)
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# --- PDF parsing (hosted LlamaParse cloud API) ---
PARSER=llamaparse
LLAMAPARSE_API_KEY=
# Cap pages sent to the parser per document (0/unset = no cap). Truncates huge PDFs
# to the first N pages so one giant paper can't stall a run or burn credits.
MAX_PDF_PAGES=

# --- Run bounds (fast, bounded runs) ---
MAX_INGEST_DOCS=                        # cap papers ingested per query (0/unset = no cap)
MAX_CHUNKS_PER_DOC=                     # cap chunks per document (0/unset = no cap)
# Per-document ingest timeout (ms). A slow/hung document is skipped after this so
# it can't stall the run. Default 120000.
INGEST_TIMEOUT_MS=

# --- Cross-service URLs (config-driven, no hardcoded host) ---
RANKING_SERVICE_URL=http://localhost:8001
PARSING_SERVICE_URL=http://localhost:8002
SYNTHESIS_SERVICE_URL=http://localhost:8003

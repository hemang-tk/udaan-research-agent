# Copy to infra/.env and adjust. Never commit the real .env.
# 12-factor: every endpoint/credential/model is config. No hardcoded localhost in code.

# --- Infra (local docker-compose; swap host/creds at deploy, no code change) ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# Required for Qdrant Cloud (managed); leave empty for a local/docker Qdrant.
QDRANT_API_KEY=

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Postgres persists research sessions (History). Unset DATABASE_URL to disable.
POSTGRES_PORT=5432
POSTGRES_USER=udaan
POSTGRES_PASSWORD=udaan
POSTGRES_DB=udaan
DATABASE_URL=postgres://udaan:udaan@localhost:5432/udaan

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000     # MinIO now -> real S3/GCS endpoint at deploy
S3_BUCKET=research-vault
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# --- Orchestrator API ---
# Orchestrator's own port (separate from the Python services' generic PORT).
ORCHESTRATOR_PORT=8080                 # change if 8080 is taken locally (e.g. Apache)
# Comma-separated origins allowed to call the API from a browser (CORS).
# Set this to your deployed frontend, e.g. https://your-site.netlify.app
# Leave empty for local dev (any origin is reflected). See DEPLOY.md.
CORS_ORIGINS=
# Phase 2 academic-graph fan-out: per-provider timeout (ms). The 4s default suits
# a datacenter but starves the gateway on a slow/residential link (0 candidates ->
# empty run). Raise to ~25000 when deploying behind a slower connection.
GATEWAY_TIMEOUT_MS=

# --- Providers (tiered, swappable — see STACK.md §4.2) ---
# Free no-cost path: LLM_PROVIDER=groq (or gemini) + set the matching API key
# below — no GPU/Ollama needed. OLLAMA_URL can stay as-is (it is unused then).
# LLM_PROVIDER may be a COMMA-SEPARATED list (e.g. "gemini,groq") to round-robin
# calls across providers and fail over on rate-limit — independent free tiers
# share the load, so a run only stalls if every provider is limited at once. Give
# each its own model via LLM_MODEL_<PROVIDER> below (LLM_MODEL is the fallback).
LLM_PROVIDER=ollama                   # ollama | gemini | groq | anthropic (or a comma list)
EMBEDDING_PROVIDER=local              # local | cohere
RERANK_PROVIDER=local                 # local | cohere
# ML_EXTRAS=1 runs the real local models (embeddings, cross-encoder reranker, sklearn
# clustering, Docling) instead of the degraded fallbacks. Requires `uv sync --extra ml`
# per service. Heavier (multi-GB, slower on CPU) but lifts degraded mode.
ML_EXTRAS=0

OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=120000               # per-request Ollama timeout (TS orchestrator), ms
OLLAMA_TIMEOUT_S=120                   # per-request Ollama timeout (Python services), seconds
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
# Per-provider model overrides — needed when LLM_PROVIDER lists several providers
# (each one wants a different model id). Falls back to LLM_MODEL when unset.
# LLM_MODEL_GEMINI=gemini-2.5-flash
# LLM_MODEL_GROQ=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# API keys (only the ones your selected providers need)
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# --- PDF parsing (Phase 5) ---
# Unset PARSER = local Docling/pypdf chain (Docling needs ML_EXTRAS=1).
# PARSER=llamaparse uses the hosted LlamaParse cloud API — no local compute,
# just a free API key (~1000 pages/day). Best for a free CPU host. See DEPLOY.md.
PARSER=
LLAMAPARSE_API_KEY=

# --- Cross-service URLs (config-driven, no hardcoded host) ---
RANKING_SERVICE_URL=http://localhost:8001
PARSING_SERVICE_URL=http://localhost:8002
SYNTHESIS_SERVICE_URL=http://localhost:8003
